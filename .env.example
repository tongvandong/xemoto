# Copy this file to .env before running docker compose.
# BẮT BUỘC đổi MSSQL_SA_PASSWORD và JWT_SECRET_KEY sang giá trị bí mật của riêng bạn trước khi
# deploy thật — các giá trị dưới đây chỉ là ví dụ, KHÔNG dùng nguyên trên VPS. Không commit file .env thật.
# JWT_SECRET_KEY phải dài tối thiểu 32 ký tự và khác hoàn toàn key trong appsettings.json (chỉ dùng cho dev).

MSSQL_DATABASE=MoToSaleV2
MSSQL_SA_PASSWORD=CHANGE_ME_StrongPassword#2026
MSSQL_PID=Developer

JWT_SECRET_KEY=CHANGE_ME_Use_A_Random_Secret_At_Least_32_Chars
JWT_ISSUER=MoToSale.Auth
JWT_AUDIENCE=MoToSale.Client
JWT_EXPIRY_MINUTES=480
