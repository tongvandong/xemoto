# URL gốc API (qua gateway). Khi chạy local thường trỏ thẳng cổng 5100.
VITE_API_BASE_URL=http://localhost:5100/api

# URL gốc để tải ảnh /uploads (ảnh sản phẩm, banner, QR...). Để trống nếu FE và API cùng origin
# (nginx proxy /uploads ở production). Chỉ cần đặt khi FE và API khác origin.
VITE_API_ASSET_BASE_URL=
